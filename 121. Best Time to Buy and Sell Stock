class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int profit = 0, max = 0, min_index = 0;
        vector<int> min(prices.size(), 1);
        
        for (int i = 0; i < prices.size(); i++) {
            min[i] = prices[i];
            if (min[i] < min[min_index]) {
                min_index = i;
            }
            if (prices[i] > min[min_index] && prices[i] - min[min_index] > profit) {
                profit = prices[i] - min[min_index];
            }
        }
        return profit;
    }
};
