class Solution {
public:
    int countPrimes(int n) {
        if (n == 0 || n == 1) {
            return 0;
        }
        vector<int> is_prime(n,1);
        is_prime[0] = 0;
        
        for (int i = 1; i < n; i++) {
            if(is_prime[i]) {
                for(int j = 2; j <= n/(i + 1); j++) {
                    is_prime[j*(i+1)-1] = 0;
                }
            }

        }
        int result = 0;
        for (int i = 0; i < n - 1; i++) {
            result += is_prime[i];
        }
        return result;
    }
};
