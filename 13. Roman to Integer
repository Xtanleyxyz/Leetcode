class Solution {
public:
    int romanToInt(string s) {
        int solution = 0;
        vector<int> pre;
        
        for (char c : s) {
            if (c == 'M') {
                pre.push_back(1000);
            }
            if (c == 'D') {
                pre.push_back(500);
            }
            if (c == 'C') {
                pre.push_back(100);
            }
            if (c == 'L') {
                pre.push_back(50);
            }
            if (c == 'X') {
                pre.push_back(10);
            }
            if (c == 'V') {
                pre.push_back(5);
            }
            if (c == 'I') {
                pre.push_back(1);
            }
        }
        
        for (int i = 0; i < pre.size(); i++) {
            if (i != pre.size() - 1 && pre[i] < pre[i + 1]) {
                solution = solution + pre[i + 1] - pre[i];
                i++;
            } else {
                solution += pre[i];
            }
        }
        
        return solution;
    }
};
