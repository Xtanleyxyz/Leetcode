class Solution {
public:
    int singleNumber(vector<int>& nums) {
        if (nums.size() == 1) {
            return nums[0];
        }
        
        int solution = 0;
        
        sort(nums.begin(), nums.end());
        
        for (int i = 1; i < nums.size(); i++) {
            if (nums[i] != nums[i - 1]) {
                solution = nums[i - 1];
                break;
            }
            if (i != nums.size() - 2) {
                i++;
            } else {
                solution = nums[i + 1];
                break;
            }
        }
        
        return solution;
    }
};
