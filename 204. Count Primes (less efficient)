class Solution {
public:
    int countPrimes(int n) {
        vector<int> prime {2};
        for (int i = 3; i < n; i = i + 2) {
            // bool is_prime = true;
            for (int j = 0; j < prime.size(); j++) {

                if (i % prime[j] == 0) {
                    break;
                } else {
//                    if (j == prime.size() - 1) {
                    if(prime[j] > (sqrt(i))) {
                        prime.push_back(i);
                        break;
                    }
                }
            }
        }
        if (n == 0 || n == 1 || n == 2) {
            return 0;
        }
        if (n == 3) {
            return 1;
        }
        return prime.size();
    }
