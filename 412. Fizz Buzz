class Solution {
public:
    vector<string> fizzBuzz(int n) {
        string Fizz = "Fizz";
        string Buzz = "Buzz";
        string FizzBuzz = "FizzBuzz";
        vector<string> answer(n, "0");
        for (int i = 1; i < n+1; i++) {
            if ((i % 3 != 0) && (i % 5 != 0)) {
                answer[i-1] = to_string(i);
            }
            if ((i % 3 == 0) && (i % 5 != 0)) {
                answer[i-1] = Fizz;
            }
            if ((i % 3 != 0) && (i % 5 == 0)) {
                answer[i-1] = Buzz;
            }
            if ((i % 3 == 0) && (i % 5 == 30)) {
                answer[i-1] = FizzBuzz;
            }
        }
        return answer;
    }
};
